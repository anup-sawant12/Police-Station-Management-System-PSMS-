<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Police Station Manager</title>
<link rel="stylesheet" href="/missingAdd.css">
<link rel="icon" href="https://www.shutterstock.com/shutterstock/photos/1396002164/display_1500/stock-vector-a-mumbai-police-logo-symbol-1396002164.jpg">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>

<body>

<!-- Navbar -->
<div class="navbar">
    <div class="logo"> <img src="https://www.shutterstock.com/shutterstock/photos/1396002164/display_1500/stock-vector-a-mumbai-police-logo-symbol-1396002164.jpg" alt="logo" width="30" height="24"> Police Station Management System (PSMS)</div>
    <div class="nav-links">
        <a href="/home">Home</a>
        <a href="/register/criminal">Add Criminals</a>
        <!-- <a href="#">Crimes</a> -->
        <a href="/officers/register">Add Officer</a>
        <a href="/complaints/register">Register Complaint</a>
        <a  href="/missing/add">Add Missing Complaint</a>
    </div>
</div>

<h1>🚨 Missing Person Entry</h1>

<div class="form-container">

<form action="/missing/add" method="POST" enctype="multipart/form-data">

    <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" required>
    </div>

    <div class="form-group">
        <label>Age</label>
        <input type="number" name="age">
    </div>

    <div class="form-group">
        <label>Gender</label>
        <select name="gender">
            <option value="Male">Male</option>
            <option value="Female">Female</option>
            <option value="Other">Other</option>
        </select>
    </div>

    <div class="form-group">
        <label>Last Seen Date</label>
        <input type="date" name="last_seen_date">
    </div>

    <div class="form-group">
        <label>Last Seen Location</label>
        <input type="text" name="last_seen_location">
    </div>

    <div class="form-group">
        <label>Description</label>
        <textarea name="description"></textarea>
    </div>

    <div class="form-group">
        <label>Contact Person</label>
        <input type="text" name="contact_person">
    </div>

    <div class="form-group">
        <label>Contact Number</label>
        <input type="text" name="contact_number">
    </div>

    <div class="form-group">
        <label>Upload Image</label>
        <input type="file" name="image" accept="image/*" required>
    </div>

    <button type="submit">Submit</button>

</form>

</div>

</body>
</html>