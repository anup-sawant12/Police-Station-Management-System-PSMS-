<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Add Complaint</title>
<link rel="stylesheet" href="/registerComplaints.css">
</head>

<body>

    <div class="navbar">
    <div class="logo"><img src="https://www.shutterstock.com/shutterstock/photos/1396002164/display_1500/stock-vector-a-mumbai-police-logo-symbol-1396002164.jpg" alt="logo" width="30" height="24"> Police Station Management System (PSMS)</div>
    <div class="nav-links">
        <a href="/home">Home</a>
        <a href="/register/criminal">Add Criminals</a>
        <!-- <a href="#">Crimes</a> -->
        <a href="/officers/register">Add Officer</a>
        <a href="/complaints/register">Register Complaints</a>
    </div>
</div>



<div class="form-container">

<form action="/complaints/register" method="POST">

    <div class="form-group">
        <label>Complainant Name</label>
        <input type="text" name="complainant_name" required>
    </div>

    <div class="form-group">
        <label>Contact Number</label>
        <input type="text" name="complainant_contact">
    </div>

    <div class="form-group">
        <label>Address</label>
        <textarea name="complainant_address"></textarea>
    </div>

    <div class="form-group">
        <label>Complaint Type</label>
        <select name="complaint_type">
            <option value="Theft">Theft</option>
            <option value="Missing">Missing</option>
            <option value="Murder">Murder</option>
            <option value="Fraud">Fraud</option>
            <option value="Other">Other</option>
        </select>
    </div>

    <div class="form-group">
        <label>Incident Date</label>
        <input type="date" name="incident_date">
    </div>

    <div class="form-group">
        <label>Incident Location</label>
        <input type="text" name="incident_location">
    </div>

    <button type="submit">Submit Complaint</button>

</form>

</div>

</body>
</html>